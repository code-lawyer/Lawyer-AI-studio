# 律所专有模板（不纳入版本控制）
.claude/templates/公司委托模板-剑桥颐华/
.claude/templates/个人委托模板-剑桥颐华/

# 通用案件模板（纳入版本控制，供SubAgent使用）
!.claude/templates/case-templates/

# 开发环境文件
.DS_Store
.vscode/
.idea/
*.tmp
*.swp
*.swo
*~

# 开发工具生成的临时文件
.specstory/

# VSCode 工作区配置文件（本地开发配置）
*.code-workspace
SuitAgent.code-workspace

# 日志文件
*.log
logs/

# 临时文件
tmp/
.tmp/

# 测试输出
test-output/
test-results/

# 依赖包
node_modules/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.env
.venv
env/
venv/

# Build artifacts
.next/
apps/web/out/
apps/api/dist/
apps/api/build/
apps/desktop/src-tauri/target/
*.egg-info/

# Package lock (keep package-lock.json for web)
package-lock.json
!apps/web/package-lock.json

# 项目文档（不纳入版本控制）
docs/
status/

# 项目输出文件（保留output目录但忽略所有内容）
output/*

# MCP 配置文件（包含 API 密钥）
.claude/mcp.json
.claude/mcp/*/config.json

# 下载文件目录（保留文件夹但忽略内容）
downloads/*

# 归档目录（临时文档、实验性功能、过渡性内容）
temp/
!docs/
!docs/product/
!docs/product/*.md
!docs/DECISIONS.md
!status/
!status/CHANGELOG.md
!status/JOURNAL.md
