{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/main/packages/api/schema.json",
  "productName": "SuitAgent",
  "version": "0.1.0",
  "identifier": "com.suitagent.app",
  "build": {
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "SuitAgent - 诉讼法律服务智能分析系统",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
