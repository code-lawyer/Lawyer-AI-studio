{
  "document_processing": {
    "primary": "mcp.mineru",
    "fallback": "skill.pdf",
    "fallback_enabled": true,
    "auto_switch": true,
    "error_reporting": true,
    "timeout_seconds": 30,
    "retry_attempts": 2
  },
  "skills": {
    "pdf": {
      "priority": 2,
      "enabled": true,
      "config": {
        "output_format": "markdown",
        "structured_only": true,
        "generate_single_file": true,
        "keep_original_filename": true
      }
    },
    "docx": {
      "priority": 3,
      "enabled": true,
      "config": {
        "output_format": "markdown",
        "structured_only": true
      }
    }
  },
  "output_standards": {
    "markdown_only": true,
    "structured_info_only": true,
    "same_directory": true,
    "keep_filename": true
  }
}