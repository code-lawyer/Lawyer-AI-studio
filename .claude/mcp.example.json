{
  "mcpServers": {
    "mineru": {
      "command": "~/Library/Python/3.13/bin/mineru-mcp",
      "env": {
        "MINERU_API_BASE": "https://mineru.net",
        "MINERU_API_KEY": "your_mineru_api_key_here",
        "OUTPUT_DIR": "./",
        "OUTPUT_IN_SAME_DIR": "true",
        "KEEP_FILENAME": "true",
        "USE_LOCAL_API": "false"
      }
    },
    "pkulaw": {
      "command": "pkulaw-mcp",
      "args": [],
      "env": {
        "PKULAW_API_KEY": "your_pkulaw_api_key_here",
        "PKULAW_BASE_URL": "https://api.pkulaw.com/v1"
      }
    }
  },
  "_description": {
    "mineru": "MinerU 文档转换服务 - PDF、图片、Word、PPT 转 Markdown",
    "pkulaw": "北大法宝法律检索服务 - 法律法规、判例、学术文献检索",
    "usage": "复制此文件到 .claude/mcp.json 并替换 your_xxx_api_key_here"
  }
}